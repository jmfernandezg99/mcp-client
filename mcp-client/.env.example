# MCP Client & Server Stack

# Configura la llave maestra para cifrar las API Keys de Gemini
# ¡DEBE TENER EXACTAMENTE 32 CARACTERES!
APP_MASTER_KEY=12345678901234567890123456789012

# Base de datos (usa localhost para correr mvnw quarkus:dev, docker-compose usa postgres automáticamente)
DB_URL=jdbc:postgresql://localhost:5432/mcp_db
DB_USER=mcp_user
DB_PASS=mcp_password
